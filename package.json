{
  "name": "@nsealr/companion-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "nsealr": "pnpm --filter @nsealr/cli nsealr",
    "nsealr-service": "pnpm --filter @nsealr/service service",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "consumer-smoke": "pnpm --filter @nsealr/consumer-smoke smoke",
    "ci": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "nostr-tools": "^2.23.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp"
    ]
  }
}
