{
  "name": "@nsealr/companion-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Secretless host-side companion packages for nSealr signer integrations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nSealr/companion.git"
  },
  "bugs": {
    "url": "https://github.com/nSealr/companion/issues"
  },
  "homepage": "https://github.com/nSealr/companion#readme",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "nsealr": "pnpm --filter @nsealr/cli nsealr",
    "nsealr-service": "pnpm --filter @nsealr/service service",
    "build": "node scripts/build_packages.mjs",
    "test": "vitest run --maxWorkers=4",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "consumer-smoke": "pnpm --filter @nsealr/consumer-smoke smoke",
    "examples-smoke": "pnpm --filter @nsealr/sdk-examples verify",
    "readme-examples:check": "node scripts/check_readme_examples.mjs",
    "api-docs:check": "node scripts/check_api_docs.mjs",
    "api-docs:update": "node scripts/check_api_docs.mjs --write",
    "api-review:check": "node scripts/check_api_review.mjs",
    "browser-runtime-imports:check": "node scripts/check_browser_runtime_imports.mjs",
    "browser-runtime-bundle:check": "node scripts/check_browser_runtime_bundle.mjs",
    "browser-extension-security:check": "node scripts/check_browser_extension_security.mjs",
    "public-imports:check": "node scripts/check_public_imports.mjs",
    "pack-smoke": "node scripts/pack_smoke.mjs",
    "release-artifacts:safety": "node scripts/check_release_artifacts_safety.mjs",
    "release-artifacts": "node scripts/prepare_release_artifacts.mjs --out release-artifacts/packages",
    "ci": "pnpm build && pnpm typecheck && pnpm test && pnpm consumer-smoke && pnpm examples-smoke && pnpm readme-examples:check && pnpm api-docs:check && pnpm api-review:check && pnpm browser-runtime-imports:check && pnpm browser-runtime-bundle:check && pnpm browser-extension-security:check && pnpm public-imports:check && pnpm release-artifacts:safety && pnpm pack-smoke"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "esbuild": "0.27.7",
    "nostr-tools": "^2.23.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@serialport/bindings-cpp",
      "esbuild"
    ]
  }
}
